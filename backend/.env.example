# Server
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/foodhub-ai

# Firebase Admin (service account JSON, base64-encoded as a single line)
